generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client" // <-- FORÇA BRUTA AQUI
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String  @id @default(cuid())
  slug             String  @unique
  name             String
  description      String
  shortDescription String
  price            Int // Centavos
  originalPrice    Int // Centavos
  images           String // Ex: "hero.jpg,detalhe.jpg"
  category         String // "kit" ou "acessorio"
  badge            String?
  isKit            Boolean @default(false)
  kitItems         String? // Ex: "Bandeira,Corneta"
  stock            Int     @default(0)
  sold             Int     @default(0)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           String  @id @default(cuid())
  orderNumber  String  @unique
  total        Int // Centavos
  status       String  @default("pendente") // pendente, pago, enviado, entregue, cancelado
  trackingCode String?

  // Dados do Cliente (Achatados)
  customerName  String
  customerCpf   String
  customerPhone String
  customerEmail String?

  // Endereço de Entrega
  addressCep      String
  addressStreet   String
  addressNumber   String
  addressComp     String?
  addressDistrict String
  addressCity     String
  addressState    String

  // Relação
  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
